NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DEMO_ALLOWED_EMAIL=you@example.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key
# Optional: separate, more restricted key for server-side Places/Directions calls.
# Falls back to NEXT_PUBLIC_GOOGLE_MAPS_API_KEY if not set.
GOOGLE_MAPS_SERVER_API_KEY=your-google-maps-server-key
OPENWEATHER_API_KEY=your-openweather-key
INSTAGRAM_ACCESS_TOKEN=your-instagram-token
TWITTER_BEARER_TOKEN=your-twitter-bearer

# Gemini (LLM)
GEMINI_API_KEY=your-gemini-api-key
# Optional: enable/disable explicitly. If omitted, Gemini is enabled automatically when GEMINI_API_KEY is set.
ENABLE_GEMINI=true
# Optional: override the default model (gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash
